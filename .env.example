# ==============================================================================
# ERPNext Production Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# ERPNext Version (Docker image tag)
# ------------------------------------------------------------------------------
ERPNEXT_VERSION=v15.95.2

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DB_PASSWORD=change-this-password

# ------------------------------------------------------------------------------
# Bind Mount Paths (relative to compose.yaml location)
# ------------------------------------------------------------------------------
SITES_PATH=./data/sites
MARIADB_PATH=./data/mariadb
REDIS_QUEUE_PATH=./data/redis-queue

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
HTTP_PUBLISH_PORT=9100

# ------------------------------------------------------------------------------
# Site Configuration
# ------------------------------------------------------------------------------
# Leave empty for auto-detection by Host header
FRAPPE_SITE_NAME_HEADER=

# Set to your domain for single-site setup
# FRAPPE_SITE_NAME_HEADER=erpnext.example.com
